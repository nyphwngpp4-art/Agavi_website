# Resend — resend.com → API Keys
RESEND_API_KEY=re_...

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV — Vercel dashboard → Storage → KV → your database → .env.local tab
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Admin — choose any strong password
ADMIN_PASSWORD=...

# Calendly — your booking page URL
CALENDLY_URL=https://calendly.com/...
